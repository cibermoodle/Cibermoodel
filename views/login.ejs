<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Iniciar sesión' %></title>
  <style>
    :root {
      --bg-1: #f7f7ed;
      --bg-2: #e8edd9;
      --card: #ffffff;
      --ink: #1c2b1f;
      --muted: #5a6a5f;
      --accent: #1e7d47;
      --accent-2: #135f35;
      --error-bg: #ffe9e5;
      --error-ink: #a4281e;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 12% 18%, #d4e8ba 0, transparent 25%),
        radial-gradient(circle at 88% 82%, #d2f1df 0, transparent 20%),
        linear-gradient(145deg, var(--bg-1), var(--bg-2));
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .login-card {
      width: min(460px, 100%);
      background: var(--card);
      border-radius: 18px;
      padding: 32px;
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.12);
    }

    h1 {
      margin: 0 0 8px;
      font-size: 1.8rem;
    }

    p {
      margin: 0 0 24px;
      color: var(--muted);
    }

    .field {
      margin-bottom: 14px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-weight: 600;
      font-size: 0.95rem;
    }

    input {
      width: 100%;
      border: 1px solid #cad4c8;
      border-radius: 10px;
      padding: 11px 12px;
      font-size: 1rem;
      outline: none;
      transition: border-color 120ms ease, box-shadow 120ms ease;
    }

    input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(30, 125, 71, 0.18);
    }

    .error {
      margin-bottom: 14px;
      border: 1px solid #ffc4bd;
      border-radius: 10px;
      background: var(--error-bg);
      color: var(--error-ink);
      padding: 10px 12px;
      font-size: 0.95rem;
    }

    button {
      width: 100%;
      border: 0;
      border-radius: 10px;
      background: var(--accent);
      color: #fff;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      padding: 12px;
      transition: background 120ms ease;
    }

    button:hover {
      background: var(--accent-2);
    }
  </style>
</head>
<body>
  <main class="login-card">
    <h1>Bienvenido</h1>
    <p>Accede con tu correo y contraseña para continuar.</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="post" action="/login" novalidate>
      <div class="field">
        <label for="email">Correo</label>
        <input id="email" type="email" name="email" value="<%= email || '' %>" required />
      </div>

      <div class="field">
        <label for="password">Contraseña</label>
        <input id="password" type="password" name="password" required />
      </div>

      <button type="submit">Iniciar sesión</button>
    </form>
  </main>
</body>
</html>
