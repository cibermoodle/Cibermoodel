<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
            <div>
              <h2 class="fw-bold mb-1">Mi perfil</h2>
              <p class="text-muted mb-0">Datos de la cuenta actualmente autenticada.</p>
            </div>
            <span class="badge rounded-pill text-bg-primary px-3 py-2 text-uppercase"><%= perfil.rol %></span>
          </div>

          <div class="row g-3">
            <div class="col-12 col-sm-6">
              <label class="form-label text-muted mb-1">Nombre</label>
              <div class="form-control bg-light"><%= perfil.nombre || '-' %></div>
            </div>

            <div class="col-12 col-sm-6">
              <label class="form-label text-muted mb-1">Apellidos</label>
              <div class="form-control bg-light"><%= perfil.apellidos || '-' %></div>
            </div>

            <div class="col-12">
              <label class="form-label text-muted mb-1">Correo</label>
              <div class="form-control bg-light"><%= perfil.email || '-' %></div>
            </div>

            <div class="col-12 col-sm-6">
              <label class="form-label text-muted mb-1">ID de usuario</label>
              <div class="form-control bg-light"><%= perfil.usuario_id %></div>
            </div>

            <div class="col-12 col-sm-6">
              <label class="form-label text-muted mb-1">Rol</label>
              <div class="form-control bg-light text-capitalize"><%= perfil.rol %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
