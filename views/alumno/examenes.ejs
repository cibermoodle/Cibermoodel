<link rel="stylesheet" href="/profesores.css">

<!-- Modal "examen completado" -->
<% const testCompletado = typeof query !== 'undefined' && query.completado ? query.completado : null; %>
<% if (testCompletado) { %>
<div id="modal-completado" style="
    position: fixed; inset: 0; z-index: 2000;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.45);
">
    <div style="
        background: #fff; border-radius: 14px; padding: 32px 36px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18); text-align: center;
        max-width: 360px; width: 90%;
    ">
        <div style="font-size: 2.5rem; margin-bottom: 10px;">🎉</div>
        <h3 style="margin: 0 0 8px 0; color: #333;">¡Examen enviado!</h3>
        <p style="color: #666; margin: 0 0 24px 0;">Tus respuestas han sido guardadas correctamente.</p>
        <div style="display: flex; flex-direction: column; gap: 10px;">
            <a href="/alumno/resultados/<%= testCompletado %>" style="
                display: block; padding: 12px 20px;
                background: #4a4aff; color: #fff; border-radius: 8px;
                text-decoration: none; font-weight: 600; font-size: 1rem;
            ">📊 Ver mis resultados</a>
            <button onclick="document.getElementById('modal-completado').remove()" style="
                padding: 10px 20px; background: #f0f0f0; color: #555;
                border: none; border-radius: 8px; cursor: pointer;
                font-size: 0.95rem;
            ">Cerrar</button>
        </div>
    </div>
</div>
<% } %>

<div class="prof-header">
    <h2 class="prof-titulo">Exámenes activos</h2>
    <a href="/alumno" class="btn-nueva-clase">← Volver al dashboard</a>
</div>

<% if (examenes.length > 0) { %>
    <div class="clases-grid" style="margin-bottom: 30px;">
        <% examenes.forEach(examen => { %>
            <div class="clase-card" style="border: 1px solid #b4b4ff;">
                <div class="clase-card-banner">
                    <p class="clase-card-banner-titulo"><%= examen.titulo %></p>
                    <a href="/alumno/examen/<%= examen.test_id %>" class="btn-editar-card">✅ Acceder</a>
                </div>
                <div class="clase-card-acciones">
                    <div class="accion-item">
                        <strong>Clase:</strong> <%= examen.clase_nombre %>
                    </div>
                    <div class="accion-item">
                        <strong>Duración:</strong> <%= examen.duracion_min %> min
                    </div>
                </div>
                <div class="clase-card-footer">
                    <span>📄 <%= examen.descripcion ? examen.descripcion.substring(0, 40) + '...' : 'Sin descripción' %></span>
                    <span>⏰ Hasta <%= examen.end_at ? new Date(examen.end_at).toLocaleString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'sin fecha' %></span>
                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <div class="clases-vacio" style="margin-bottom: 30px;">
        <div class="icono">📝</div>
        <p>No tienes exámenes activos disponibles ahora mismo.</p>
        <p>Comprueba la fecha de inicio y duración de los exámenes asignados.</p>
    </div>
<% } %>

