<div class="container py-5">
  <h2 class="mb-1 fw-bold">Panel de administración</h2>
  <p class="text-muted mb-5">Gestión de usuarios de la plataforma</p>

  <div class="row g-4">

    <!-- Crear Profesor -->
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body d-flex flex-column align-items-start p-4">
          <div class="rounded-3 p-3 mb-3" style="background:#fef3c7;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h5 class="fw-bold mb-1">Crear Profesor</h5>
          <p class="text-muted small mb-4">Añade un nuevo profesor a la plataforma con su correo y contraseña.</p>
          <div class="d-flex gap-2 mt-auto flex-wrap">
            <a href="/admin/crear-profesor" class="btn px-4 py-2 fw-semibold" style="background:#d97706;color:#fff;border-radius:10px;">
              Crear Profesor
            </a>
            <a href="/admin/profesores" class="btn px-4 py-2 fw-semibold" style="border:1px solid #d97706;color:#d97706;border-radius:10px;">
              Ver Profesores
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Crear Alumno -->
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body d-flex flex-column align-items-start p-4">
          <div class="rounded-3 p-3 mb-3" style="background:#dcfce7;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#15803d" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <h5 class="fw-bold mb-1">Crear Alumno</h5>
          <p class="text-muted small mb-4">Añade un nuevo alumno a la plataforma con su correo y contraseña.</p>
          <div class="d-flex gap-2 mt-auto flex-wrap">
            <a href="/admin/crear-alumno" class="btn px-4 py-2 fw-semibold" style="background:#15803d;color:#fff;border-radius:10px;">
              Crear Alumno
            </a>
            <a href="/admin/alumnos" class="btn px-4 py-2 fw-semibold" style="border:1px solid #15803d;color:#15803d;border-radius:10px;">
              Ver Alumnos
            </a>
          </div>
        </div>
      </div>
    </div>

      <!-- Crear Administrador -->
      <div class="col-12 col-md-6 mx-auto">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body d-flex flex-column align-items-start p-4">
            <div class="rounded-3 p-3 mb-3" style="background:#dbeafe;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 8v6"/>
                <path d="M20 11h6"/>
              </svg>
            </div>
            <h5 class="fw-bold mb-1">Crear Administrador</h5>
            <p class="text-muted small mb-4">Añade un nuevo administrador para gestionar la plataforma.</p>
            <div class="d-flex gap-2 mt-auto flex-wrap">
              <a href="/admin/crear-administrador" class="btn px-4 py-2 fw-semibold" style="background:#1d4ed8;color:#fff;border-radius:10px;">
                Crear Administrador
              </a>
              <a href="/admin/administradores" class="btn px-4 py-2 fw-semibold" style="border:1px solid #1d4ed8;color:#1d4ed8;border-radius:10px;">
                Ver Administradores
              </a>
            </div>
          </div>
        </div>
      </div>

  </div>
</div>
