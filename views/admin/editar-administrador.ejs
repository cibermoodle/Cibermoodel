<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-6">

      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin/administradores" class="btn btn-sm btn-outline-secondary px-3">&larr; Volver</a>
        <div>
          <h2 class="fw-bold mb-0">Editar Administrador</h2>
          <p class="text-muted small mb-0">Actualiza los datos del administrador seleccionado.</p>
        </div>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <form action="/admin/administradores/<%= datos.usuario_id %>/editar" method="POST">
            <div class="row g-3">
              <div class="col-12 col-sm-6">
                <label class="form-label fw-semibold" for="nombre">Nombre</label>
                <input id="nombre" type="text" name="nombre" class="form-control" value="<%= datos.nombre %>" required>
              </div>

              <div class="col-12 col-sm-6">
                <label class="form-label fw-semibold" for="apellidos">Apellidos</label>
                <input id="apellidos" type="text" name="apellidos" class="form-control" value="<%= datos.apellidos %>" required>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="email">Correo electronico</label>
                <input id="email" type="email" name="email" class="form-control" value="<%= datos.email %>" required>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="password">Nueva contraseña <span class="text-muted fw-normal">(opcional)</span></label>
                <input id="password" type="password" name="password" class="form-control" minlength="8">
                <div class="form-text">Deja este campo vacío para mantener la contraseña actual. Si cambias, usa mínimo 8 caracteres, 1 mayúscula, 1 número y 1 carácter especial.</div>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="password_confirm">Verificar contraseña nueva <span class="text-muted fw-normal">(opcional)</span></label>
                <input id="password_confirm" type="password" name="password_confirm" class="form-control" minlength="8">
                <div class="form-text">Solo es necesario si vas a cambiar la contraseña y debe coincidir exactamente.</div>
              </div>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold text-white" style="background:#1d4ed8;border-radius:10px;">
                Guardar cambios
              </button>
              <a href="/admin/administradores" class="btn btn-outline-secondary px-4 py-2">Cancelar</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>