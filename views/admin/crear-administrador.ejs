<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-6">

      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin" class="btn btn-sm btn-outline-secondary px-3">&larr; Volver</a>
        <a href="/admin/administradores" class="btn btn-sm px-3 text-white" style="background:#1d4ed8;">Ver todos los administradores</a>
        <div>
          <h2 class="fw-bold mb-0">Crear Administrador</h2>
          <p class="text-muted small mb-0">Rellena los datos para registrar un nuevo administrador.</p>
        </div>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (typeof exito !== 'undefined' && exito) { %>
        <div class="alert alert-success"><%= exito %></div>
      <% } %>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <form action="/admin/crear-administrador" method="POST">
            <div class="row g-3">
              <div class="col-12 col-sm-6">
                <label class="form-label fw-semibold" for="nombre">Nombre</label>
                <input id="nombre" type="text" name="nombre" class="form-control"
                       value="<%= typeof datos !== 'undefined' ? datos.nombre : '' %>" required>
              </div>

              <div class="col-12 col-sm-6">
                <label class="form-label fw-semibold" for="apellidos">Apellidos</label>
                <input id="apellidos" type="text" name="apellidos" class="form-control"
                       value="<%= typeof datos !== 'undefined' ? datos.apellidos : '' %>" required>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="email">Correo electronico</label>
                <input id="email" type="email" name="email" class="form-control"
                       value="<%= typeof datos !== 'undefined' ? datos.email : '' %>" required>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="password">Contraseña</label>
                <input id="password" type="password" name="password" class="form-control"
                       minlength="8" required>
                <div class="form-text">Mínimo 8 caracteres, 1 mayúscula, 1 número y 1 carácter especial.</div>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold" for="password_confirm">Verificar contraseña</label>
                <input id="password_confirm" type="password" name="password_confirm" class="form-control"
                       minlength="8" required>
                <div class="form-text">Debe coincidir exactamente con la contraseña.</div>
              </div>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold text-white"
                      style="background:#1d4ed8;border-radius:10px;">
                Crear Administrador
              </button>
              <a href="/admin" class="btn btn-outline-secondary px-4 py-2">Cancelar</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>