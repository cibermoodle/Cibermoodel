<div class="container py-5">
  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
      <h2 class="fw-bold mb-1">Todos los alumnos</h2>
      <p class="text-muted mb-0">Listado completo de alumnos registrados.</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/admin" class="btn btn-outline-secondary">Volver al panel</a>
      <a href="/admin/crear-alumno" class="btn text-white" style="background:#15803d;">Crear alumno</a>
    </div>
  </div>

  <form method="GET" action="/admin/alumnos" class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-center">
      <input
        type="text"
        name="q"
        class="form-control"
        style="max-width: 380px;"
        placeholder="Buscar por nombre, apellidos o email"
        value="<%= q || '' %>"
      >
      <button type="submit" class="btn text-white" style="background:#15803d;">Buscar</button>
      <a href="/admin/alumnos" class="btn btn-outline-secondary">Limpiar</a>
    </div>
  </form>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>ID Alumno</th>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Email</th>
            <th>Fecha nacimiento</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (!alumnos || alumnos.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">No hay alumnos registrados.</td>
            </tr>
          <% } else { %>
            <% alumnos.forEach(alumno => { %>
              <tr>
                <td><%= alumno.alumno_id %></td>
                <td><%= alumno.nombre %></td>
                <td><%= alumno.apellidos %></td>
                <td><%= alumno.email %></td>
                <td><%= alumno.fecha_nacimiento ? new Date(alumno.fecha_nacimiento).toISOString().slice(0, 10) : '-' %></td>
                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <a href="/admin/alumnos/<%= alumno.alumno_id %>/editar" class="btn btn-sm btn-outline-warning">Editar</a>
                    <form action="/admin/alumnos/<%= alumno.alumno_id %>/eliminar" method="POST" onsubmit="return confirm('¿Eliminar alumno?');" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
