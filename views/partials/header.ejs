<%
  const unreadCount = (notificaciones || []).filter(n => !n.leida).length;
  const apellidoParaUI = user ? (user.apellido || user.apellidos || '') : '';
  const iniciales = user
    ? user.nombre.charAt(0).toUpperCase() + (apellidoParaUI.charAt(0) || '').toUpperCase()
    : 'US';
%>


<header class="header">

  <!-- LOGO -->
  <div class="logo-area">
    <a class="moodle-logo" href="/inicio">
      <div class="moodle-icon">
        <svg width="24" height="24" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 72V38c0-3 2-5 5-5h6c3 0 5 2 5 5v34h10V50c0-3 2-5 5-5h6c3 0 5 2 5 5v22h10V46c0-3 2-5 5-5h6c3 0 5 2 5 5v26"
            stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="moodle-text">
        <span>Cibermoodle</span>
        <span>Campus Virtual</span>
      </div>
    </a>
  </div>

  <!-- NOMBRE DEL CENTRO -->
  <div class="centro-info">
    Centro: &nbsp;<strong><%= typeof centro !== 'undefined' ? centro : 'I.E.S. Mar de Cádiz' %></strong>
  </div>

  <!-- NAVEGACIÓN -->
  <nav class="nav-area">
    <a href="/cursos"     class="nav-link <%= paginaActual === 'cursos'     ? 'active' : '' %>">Mis cursos</a>
    <a href="/tareas"     class="nav-link <%= paginaActual === 'tareas'     ? 'active' : '' %>">Tareas</a>
    <a href="/proyectos"  class="nav-link <%= paginaActual === 'proyectos'  ? 'active' : '' %>">Proyectos</a>
    <a href="/calendario" class="nav-link <%= paginaActual === 'calendario' ? 'active' : '' %>">Calendario</a>
    <% if (user && user.rol === 'profesor') { %>
    <a href="/mis-clases" class="nav-link nav-link--teacher <%= paginaActual === 'mis-clases' ? 'active' : '' %>">Mis clases</a>
    <a href="/profesor/banco-preguntas" class="nav-link nav-link--teacher <%= paginaActual === 'banco-preguntas' ? 'active' : '' %>">📚 Banco Preguntas</a>
    <% } %>
  </nav>

  <!-- TOOLBAR -->
  <div class="toolbar">

    <!-- Ayuda -->
    <button class="icon-btn" title="Ayuda">?</button>

    <!-- Notificaciones -->
    <div class="dropdown-wrapper" id="notifWrapper">
      <button class="icon-btn" id="notifBtn" title="Notificaciones">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <% if (unreadCount > 0) { %>
          <span class="notif-badge"><%= unreadCount > 9 ? '9+' : unreadCount %></span>
        <% } %>
      </button>

      <div class="dropdown-menu notif-menu" id="notifMenu">
        <div class="dropdown-head">
          <span>Notificaciones</span>
          <% if (unreadCount > 0) { %>
            <a href="/notificaciones/leidas">Marcar todas</a>
          <% } %>
        </div>
        <ul class="notif-list">
          <% if ((notificaciones || []).length === 0) { %>
            <li class="notif-empty">Sin notificaciones nuevas</li>
          <% } else { %>
            <% (notificaciones || []).slice(0, 5).forEach(n => { %>
              <li class="notif-item <%= !n.leida ? 'unread' : '' %>">
                <span class="notif-dot"></span>
                <div>
                  <p class="notif-text"><%= n.texto %></p>
                  <time class="notif-time"><%= n.fecha %></time>
                </div>
              </li>
            <% }) %>
          <% } %>
        </ul>
        <a href="/notificaciones" class="dropdown-foot">Ver todas las notificaciones</a>
      </div>
    </div>

    <!-- Mensajes -->
    <button class="icon-btn" title="Mensajes" onclick="location.href='/mensajes'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </button>

    <!-- Avatar + dropdown perfil -->
    <div class="dropdown-wrapper" id="profileWrapper">
      <div
        class="avatar-wrapper"
        id="profileBtn"
        role="button"
        tabindex="0"
        aria-haspopup="true"
        aria-expanded="false"
        onkeydown="if(event.key==='Enter' || event.key===' '){event.preventDefault(); this.click();}"
      >
        <div class="avatar"><%= iniciales %></div>
        <span>▾</span>
      </div>

      <div class="dropdown-menu profile-menu" id="profileMenu">
        <div class="profile-menu-header">
          <span class="profile-menu-name"><%= user ? user.nombre + ' ' + apellidoParaUI : 'Usuario' %></span>
          <span class="profile-menu-email"><%= user && user.email ? user.email : '' %></span>
          <span class="rol-badge <%= user && user.rol === 'profesor' ? 'rol-profesor' : user && user.rol === 'admin' ? 'rol-admin' : 'rol-alumno' %>">
            <%= user && user.rol === 'profesor' ? 'Profesor' : user && user.rol === 'admin' ? 'Administrador' : 'Alumno' %>
          </span>
        </div>
        <a href="/perfil" class="menu-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Mi perfil
        </a>
        <div class="menu-divider"></div>
        <a href="/logout" class="menu-item menu-item--danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Cerrar sesión
        </a>
      </div>
    </div>

    <!-- Modo edición (solo profesores) -->
    <% if (user && user.rol === 'profesor') { %>
    <span class="edit-mode-label">Modo de edición</span>
    <label class="toggle" title="Activar modo edición">
      <input type="checkbox" id="editToggle">
      <span class="slider"></span>
    </label>
    <% } %>

  </div>
</header>

<script>
(function () {
  const notifBtn    = document.getElementById('notifBtn');
  const notifMenu   = document.getElementById('notifMenu');
  const profileBtn  = document.getElementById('profileBtn');
  const profileMenu = document.getElementById('profileMenu');

  function closeMenu(menu) {
    if (menu) {
      menu.classList.remove('open');
    }
  }

  function toggleMenu(menu, other) {
    if (!menu) {
      return;
    }

    closeMenu(other);
    menu.classList.toggle('open');
  }

  if (notifBtn) {
    notifBtn.addEventListener('click', e => {
      e.stopPropagation();
      toggleMenu(notifMenu, profileMenu);
    });
  }

  if (profileBtn) {
    profileBtn.addEventListener('click', e => {
      e.stopPropagation();
      toggleMenu(profileMenu, notifMenu);
    });
  }

  document.addEventListener('click', () => {
    closeMenu(notifMenu);
    closeMenu(profileMenu);
  });

  if (notifMenu) {
    notifMenu.addEventListener('click', e => e.stopPropagation());
  }

  if (profileMenu) {
    profileMenu.addEventListener('click', e => e.stopPropagation());
  }
})();
</script>

