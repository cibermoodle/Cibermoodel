<link rel="stylesheet" href="../../public/profesores.css">

<style>
.prof-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 24px 0 20px;
}
.prof-titulo { margin: 0; font-size: 1.3rem; color: #333; font-weight: 600; }

.btn-nueva-clase {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #1a5276;
    color: white;
    padding: 9px 18px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
}
.btn-nueva-clase:hover { background: #154360; color: white; text-decoration: none; }

.clases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
@media (max-width: 900px) { .clases-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .clases-grid { grid-template-columns: 1fr; } }

.clase-card {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    background: white;
    transition: box-shadow 0.2s, opacity 0.3s, transform 0.3s;
}
.clase-card:hover { box-shadow: 0 3px 12px rgba(0,0,0,0.2); }

.clase-card-banner {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #1a3a5c 0%, #1a3a5ccc 100%);
    display: flex;
    align-items: flex-end;
    padding: 12px 16px;
    box-sizing: border-box;
    position: relative;
}
.clase-card-banner-titulo {
    color: white;
    font-size: 1.05rem;
    font-weight: 600;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
}
.btn-editar-card {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.5);
    color: white;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.72rem;
    text-decoration: none;
    font-weight: 600;
    backdrop-filter: blur(2px);
    transition: background 0.15s;
}
.btn-editar-card:hover { background: rgba(255,255,255,0.35); color: white; text-decoration: none; }

.btn-eliminar-card {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(192,57,43,0.7);
    border: 1px solid rgba(255,255,255,0.5);
    color: white;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(2px);
    transition: background 0.15s;
}
.btn-eliminar-card:hover { background: rgba(192,57,43,0.95); }

.clase-card-acciones {
    display: flex;
    justify-content: space-around;
    padding: 10px 8px;
    border-top: 1px solid #e8eaed;
    background: white;
}
.accion-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: #555;
    font-size: 0.7rem;
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 4px;
    transition: background 0.15s;
}
.accion-item:hover { background: #f0f3f7; color: #1a5276; text-decoration: none; }
.accion-item svg { width: 20px; height: 20px; stroke: currentColor; }

.clase-card-footer {
    padding: 8px 16px;
    background: #f8f9fa;
    border-top: 1px solid #e8eaed;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: #666;
}
.codigo-badge {
    background: #eaf4fb;
    color: #1a5276;
    border: 1px solid #aed6f1;
    border-radius: 4px;
    padding: 2px 8px;
    font-weight: 700;
    letter-spacing: 1px;
    font-size: 0.75rem;
}
.clases-vacio {
    text-align: center;
    padding: 80px 20px;
    color: #888;
}
.clases-vacio .icono { font-size: 4rem; margin-bottom: 16px; }
.clases-vacio p { font-size: 1rem; margin-bottom: 20px; }
</style>

<div class="prof-header">
    <h2 class="prof-titulo">Vista de clases</h2>
    <a href="/profesor/crearclase" class="btn-nueva-clase">＋ Nueva clase</a>
</div>

<% if (clases.length === 0) { %>
    <div class="clases-vacio">
        <div class="icono">📚</div>
        <p>Aún no tienes ninguna clase creada.</p>
        <a href="/profesor/crearclase" class="btn-nueva-clase">＋ Crear primera clase</a>
    </div>
<% } else { %>
    <div class="clases-grid">
        <% clases.forEach(clase => { %>
        <div class="clase-card" data-id="<%= clase.clase_id %>">
            <div class="clase-card-banner">
                <p class="clase-card-banner-titulo"><%= clase.nombre %></p>
                <a href="/profesor/editarclase/<%= clase.clase_id %>" class="btn-editar-card">✏️ Editar</a>
                <button class="btn-eliminar-card" onclick="eliminarClase(this, <%= clase.clase_id %>)">🗑️ Eliminar</button>
            </div>
            <div class="clase-card-acciones">
                <a href="#" class="accion-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
                    Cuestionario
                </a>
                <a href="#" class="accion-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                    Foro
                </a>
                <a href="#" class="accion-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Calificaciones
                </a>
               <!-- <a href="#" class="accion-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                    Recursos
                </a> -->
            </div>
            <div class="clase-card-footer">
                <span>Código: <span class="codigo-badge"><%= clase.codigo_acceso %></span></span>
                <span><%= clase.activa === 'activa' ? '✅ Activa' : '⏸ Inactiva' %></span>
            </div>
        </div>
        <% }) %>
    </div>
<% } %>

<script>
document.querySelectorAll('.clase-card').forEach(card => {
    const id = card.dataset.id;
    const color = localStorage.getItem('clase_color_' + id);
    if (color) {
        card.querySelector('.clase-card-banner').style.background =
            `linear-gradient(135deg, ${color} 0%, ${color}cc 100%)`;
    }
});

async function eliminarClase(btn, id) {
    if (!confirm('¿Seguro que quieres eliminar esta clase?')) return;

    const card = btn.closest('.clase-card');

    try {
        const res = await fetch(`/profesor/eliminarclase/${id}`, { method: 'POST' });
        if (res.ok || res.redirected) {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => card.remove(), 300);
        } else {
            alert('Error al eliminar la clase.');
        }
    } catch (err) {
        alert('Error de conexión.');
    }
}
</script>